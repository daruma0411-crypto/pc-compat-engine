
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    /* 背景レイヤー */
    --bg-outer:  #1D2229;
    --bg-main:   #232930;
    --bg-card:   #303740;
    --bg-input:  #3D454F;
    --bg-active: #444C57;

    /* 状態色（Figma パレット） */
    --c-ok:      #78FFCB;
    --c-ok-bg:   #1a3d31;
    --c-warn:    #FFD978;
    --c-warn-bg: #3d3620;
    --c-ng:      #FF9178;
    --c-ng-bg:   #3d2420;
    --c-unk:     #BBC2CA;
    --c-unk-bg:  #2A3038;

    /* テキスト */
    --c-text:    #EAECEF;
    --c-sub:     #CDD2D8;
    --c-muted:   #BBC2CA;

    /* アクセント */
    --c-primary: #9ECFFF;
    --c-surface: #303740;
    --c-border:  #606975;
    --radius:    12px;
    --shadow:    0 4px 16px rgba(0,0,0,.35);
  }

  html, body {
    height: 100%;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", "Hiragino Sans", sans-serif;
    background: var(--bg-outer);
    color: var(--c-text);
  }

  /* ── アプリシェル ── */
  .app {
    display: flex;
    flex-direction: column;
    height: 100vh;
    max-width: 1400px;
    margin: 0 auto;
    background: var(--bg-outer);
  }
  
  /* デスクトップレイアウト: メインコンテンツ + サイドバー */
  @media (min-width: 1024px) {
    .app {
      display: grid;
      grid-template-columns: 1fr 320px;
      grid-template-rows: auto 1fr auto;
      grid-template-areas:
        "header header"
        "chat sidebar"
        "footer footer";
    }
    
    header { grid-area: header; }
    .chat-area { grid-area: chat; }
    .chat-footer { grid-area: footer; }
    .featured-games {
      grid-area: sidebar;
      max-height: calc(100vh - 120px);
      border-left: 1px solid var(--c-border);
      border-bottom: none;
    }
  }

  /* ── ヘッダー ── */
  header {
    flex-shrink: 0;
    background: var(--bg-main);
    color: var(--c-text);
    padding: 14px 20px;
    display: flex;
    align-items: center;
    gap: 12px;
    border-bottom: 1px solid var(--c-border);
  }

  .btn-menu {
    width: 36px; height: 36px;
    border-radius: 8px;
    background: none;
    border: 1px solid var(--c-border);
    color: var(--c-muted);
    font-size: 15px;
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
    transition: background .15s;
  }
  .btn-menu:hover { background: var(--bg-active); }

  .header-logo {
    width: 36px; height: 36px;
    border-radius: 12px;
    background: radial-gradient(100% 100% at 50% 100%, #0059B2 0%, #008AB0 100%);
    flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
    font-size: 18px;
  }

  .header-title { flex: 1; }
  .header-title h1 { font-size: clamp(13px, 3.5vw, 17px); font-weight: 700; color: var(--c-sub); }
  .header-title p  { font-size: 11px; color: var(--c-muted); margin-top: 2px; }

  /* ── ドロワー ── */
  .drawer-overlay {
    display: none;
    position: fixed; inset: 0;
    background: rgba(0,0,0,.55);
    z-index: 100;
  }
  .drawer-overlay.open { display: block; }

  .drawer {
    position: fixed;
    top: 0; left: 0; bottom: 0;
    width: 300px;
    background: var(--bg-main);
    border-right: 1px solid var(--c-border);
    z-index: 101;
    display: flex;
    flex-direction: column;
    transform: translateX(-100%);
    transition: transform .22s ease;
  }
  .drawer-overlay.open .drawer { transform: translateX(0); }

  .drawer-header {
    padding: 16px 20px;
    border-bottom: 1px solid var(--c-border);
    display: flex; align-items: center; justify-content: space-between;
  }
  .drawer-header h2 { font-size: 14px; font-weight: 700; color: var(--c-sub); }

  .btn-drawer-close {
    background: none; border: none;
    color: var(--c-muted); font-size: 18px; cursor: pointer;
    line-height: 1;
  }

  .btn-new-chat {
    margin: 12px 16px;
    padding: 10px 16px;
    background: var(--bg-active);
    border: 1px solid var(--c-border);
    border-radius: 8px;
    color: var(--c-text);
    font-size: 13px; font-weight: 600;
    cursor: pointer;
    display: flex; align-items: center; gap: 8px;
    transition: background .15s;
    font-family: inherit;
    width: calc(100% - 32px);
  }
  .btn-new-chat:hover { background: var(--bg-input); }

  .drawer-list {
    flex: 1; overflow-y: auto;
    padding: 4px 8px 16px;
  }
  .drawer-list::-webkit-scrollbar { width: 4px; }
  .drawer-list::-webkit-scrollbar-thumb { background: #606975; border-radius: 2px; }

  .drawer-section-title {
    font-size: 10px; font-weight: 700; color: var(--c-muted);
    padding: 10px 12px 4px;
    letter-spacing: .06em; text-transform: uppercase;
  }
  .drawer-item {
    display: flex; align-items: center; gap: 8px;
    padding: 10px 12px;
    border-radius: 8px;
    cursor: default;
    font-size: 13px; color: var(--c-sub);
    border-left: 2px solid transparent;
    transition: background .1s;
  }
  .drawer-item:hover { background: var(--bg-active); border-left-color: var(--c-primary); }
  .drawer-item-icon  { font-size: 14px; flex-shrink: 0; }
  .drawer-item-title { flex: 1; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .drawer-item-date  { font-size: 10px; color: var(--c-muted); flex-shrink: 0; }
  .drawer-empty { padding: 20px 16px; font-size: 12px; color: var(--c-muted); }

  /* ── チャット欄 ── */
  .chat-area {
    flex: 1;
    overflow-y: auto;
    padding: 20px 16px 8px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .chat-area::-webkit-scrollbar { width: 6px; }
  .chat-area::-webkit-scrollbar-track { background: transparent; }
  .chat-area::-webkit-scrollbar-thumb { background: #606975; border-radius: 3px; }

  /* ── メッセージバブル ── */
  .msg {
    display: flex;
    align-items: flex-end;
    gap: 8px;
    animation: fadeUp .2s ease;
  }
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .msg.ai   { align-self: flex-start; max-width: 90%; }
  .msg.user { align-self: flex-end;   max-width: 80%; flex-direction: row-reverse; }

  .msg-avatar {
    width: 30px; height: 30px;
    border-radius: 50%;
    flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
    font-size: 15px;
    background: radial-gradient(100% 100% at 50% 100%, #0059B2 0%, #008AB0 100%);
    color: #fff;
  }
  .msg.user .msg-avatar { background: var(--bg-active); }

  .msg-bubble {
    background: var(--bg-card);
    border: 1px solid var(--c-border);
    border-radius: 16px;
    padding: 10px 14px;
    font-size: 14px;
    line-height: 1.6;
    box-shadow: var(--shadow);
    word-break: break-word;
    color: var(--c-text);
  }
  .msg.ai   .msg-bubble { border-bottom-left-radius: 4px; }
  .msg.user .msg-bubble {
    border-bottom-right-radius: 4px;
    background: var(--bg-input);
  }

  /* タイピングアニメーション */
  .typing-indicator {
    display: flex;
    gap: 4px;
    padding: 4px 2px;
    align-items: center;
  }
  .typing-indicator span {
    width: 7px; height: 7px;
    background: var(--c-primary);
    border-radius: 50%;
    animation: bounce .9s infinite;
  }
  .typing-indicator span:nth-child(2) { animation-delay: .18s; }
  .typing-indicator span:nth-child(3) { animation-delay: .36s; }
  @keyframes bounce {
    0%, 60%, 100% { transform: translateY(0); }
    30%           { transform: translateY(-6px); }
  }

  /* ── 診断カード ── */
  .diag-card {
    background: var(--bg-card);
    border: 1px solid var(--c-border);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    overflow: hidden;
    margin-top: 10px;
    width: min(460px, 75vw);
  }

  .verdict-banner {
    padding: 13px 15px;
    display: flex;
    align-items: center;
    gap: 11px;
    border-bottom: 1px solid rgba(255,255,255,.07);
  }
  .verdict-banner.OK      { background: var(--c-ok-bg); }
  .verdict-banner.WARNING { background: var(--c-warn-bg); }
  .verdict-banner.NG      { background: var(--c-ng-bg); }
  .verdict-banner.UNKNOWN { background: var(--bg-active); }

  .verdict-icon { font-size: 22px; flex-shrink: 0; line-height: 1; }
  .verdict-text h2 { font-size: 16px; font-weight: 700; }
  .verdict-text h2.OK      { color: var(--c-ok); }
  .verdict-text h2.WARNING { color: var(--c-warn); }
  .verdict-text h2.NG      { color: var(--c-ng); }
  .verdict-text h2.UNKNOWN { color: var(--c-unk); }
  .verdict-text p  { font-size: 12px; color: var(--c-muted); margin-top: 2px; }

  .checks-list { padding: 4px 0; }
  .check-item {
    display: flex;
    align-items: flex-start;
    gap: 9px;
    padding: 9px 13px;
    border-bottom: 1px solid rgba(255,255,255,.05);
    font-size: 13px;
  }
  .check-item:last-child { border-bottom: none; }
  .check-badge {
    font-size: 10px;
    font-weight: 700;
    padding: 2px 6px;
    border-radius: 20px;
    flex-shrink: 0;
    margin-top: 1px;
    letter-spacing: .04em;
  }
  .badge-OK      { background: var(--c-ok-bg);   color: var(--c-ok);   border: 1px solid #2a6347; }
  .badge-WARNING { background: var(--c-warn-bg); color: var(--c-warn); border: 1px solid #6b5e30; }
  .badge-NG      { background: var(--c-ng-bg);   color: var(--c-ng);   border: 1px solid #6b3e30; }
  .badge-UNKNOWN { background: var(--c-unk-bg);  color: var(--c-unk);  border: 1px solid var(--c-border); }
  .check-name   { font-weight: 600; margin-bottom: 2px; color: var(--c-text); }
  .check-detail { color: var(--c-muted); line-height: 1.4; }

  /* ── 代替品カードグリッド ── */
  .alt-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 8px;
    margin-top: 10px;
    width: min(460px, 75vw);
  }
  .alt-product {
    background: var(--bg-card);
    border: 1px solid var(--c-border);
    border-radius: 10px;
    box-shadow: var(--shadow);
    padding: 11px 12px;
  }
  .alt-name {
    font-weight: 700;
    font-size: 13px;
    color: var(--c-text);
    margin-bottom: 4px;
    line-height: 1.3;
  }
  .alt-specs {
    color: var(--c-muted);
    font-size: 11px;
    margin-bottom: 7px;
    line-height: 1.5;
  }
  .alt-links {
    display: flex;
    gap: 5px;
    flex-wrap: wrap;
  }
  .buy-btn {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 5px 9px;
    border-radius: 5px;
    font-size: 11px;
    font-weight: 600;
    background: transparent;
    border: 1px solid var(--c-border);
    color: var(--c-sub);
    text-decoration: none;
    cursor: pointer;
    transition: background .15s, color .15s, border-color .15s;
    white-space: nowrap;
  }
  .buy-btn:hover { background: var(--bg-active); color: var(--c-text); border-color: var(--c-primary); }
  .buy-btn-amazon  { }
  .buy-btn-rakuten { }

  /* ── 予算表示 ── */
  .summary-budget-label {
    font-size: 12px;
    color: var(--c-muted);
  }
  .summary-budget-warn {
    margin-top: 6px;
    padding: 6px 10px;
    border-radius: 6px;
    font-size: 13px;
    font-weight: 600;
    background: rgba(255, 145, 115, 0.15);
    color: #ff9a8c;
    border: 1px solid rgba(255, 145, 115, 0.3);
  }
  .summary-budget-ok {
    margin-top: 6px;
    padding: 6px 10px;
    border-radius: 6px;
    font-size: 13px;
    font-weight: 600;
    background: rgba(120, 255, 203, 0.15);
    color: #78FFCB;
    border: 1px solid rgba(120, 255, 203, 0.3);
  }

  /* ── フッター入力欄 ── */
  .chat-footer {
    flex-shrink: 0;
    background: var(--bg-main);
    border-top: 1px solid var(--c-border);
    padding: 10px 14px;
    display: flex;
    gap: 8px;
    align-items: flex-end;
  }
  .chat-input {
    flex: 1;
    border: 1px solid #87909C;
    border-radius: 10px;
    padding: 10px 16px;
    font-size: 14px;
    font-family: inherit;
    resize: none;
    outline: none;
    line-height: 1.5;
    max-height: 120px;
    overflow-y: auto;
    transition: border-color .15s;
    background: var(--bg-input);
    color: var(--c-text);
  }
  .chat-input:focus {
    border-color: var(--c-primary);
    box-shadow: 0 0 0 3px rgba(158,207,255,.15);
  }
  .chat-input::placeholder { color: var(--c-muted); }
  .chat-input:disabled { opacity: .5; }

  .btn-send {
    width: 42px; height: 42px;
    border-radius: 10px;
    background: var(--c-primary);
    color: #1D2229;
    border: none;
    font-size: 18px;
    cursor: pointer;
    flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
    transition: opacity .15s, transform .1s;
    line-height: 1;
    font-weight: 700;
  }
  .btn-send:hover  { opacity: .9; }
  .btn-send:active { transform: scale(.94); }
  .btn-send:disabled { opacity: .3; cursor: not-allowed; }

  /* ── 起動時カード ── */
  .mode-cards {
    display: flex;
    gap: 10px;
    margin-top: 12px;
  }
  .mode-card {
    flex: 1;
    min-width: 120px;
    background: var(--bg-card);
    border: 1px solid var(--c-border);
    border-left: 3px solid transparent;
    border-radius: 8px;
    padding: 16px 12px;
    text-align: center;
    cursor: pointer;
    transition: background .15s, border-color .15s, transform .1s;
    font-size: 13px;
    font-weight: 600;
    color: var(--c-sub);
    line-height: 1.5;
    white-space: nowrap;
  }
  .mode-card:hover {
    background: var(--bg-active);
    border-left-color: var(--c-primary);
    transform: translateY(-2px);
  }
  .mode-card-icon {
    font-size: 28px;
    display: block;
    margin-bottom: 6px;
  }

  /* ── ゲームモード 推奨構成カード ── */
  .build-card {
    background: var(--bg-card);
    border: 1px solid var(--c-border);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    padding: 14px 16px;
    margin-top: 10px;
    width: min(460px, 75vw);
  }
  .build-game-title {
    font-size: 13px;
    font-weight: 700;
    color: var(--c-primary);
    margin-bottom: 10px;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .build-items { display: flex; flex-direction: column; gap: 8px; }
  .build-item {
    background: var(--bg-input);
    border-radius: 8px;
    border-left: 2px solid var(--c-primary);
    padding: 10px 12px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .build-item-header {
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .build-thumb {
    width: 48px;
    height: 48px;
    border-radius: 6px;
    object-fit: contain;
    background: var(--bg-main);
    flex-shrink: 0;
  }
  .build-thumb-icon {
    width: 48px;
    height: 48px;
    border-radius: 6px;
    background: var(--bg-main);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 22px;
    flex-shrink: 0;
  }
  .build-category {
    font-size: 10px;
    font-weight: 700;
    background: rgba(158,207,255,.15);
    color: var(--c-primary);
    padding: 2px 7px;
    border-radius: 999px;
    border: 1px solid rgba(158,207,255,.3);
  }
  .build-category[data-cat="GPU"]  { color: #4CAF50; border-color: rgba(76,175,80,.4);  background: rgba(76,175,80,.12); }
  .build-category[data-cat="CPU"]  { color: #2196F3; border-color: rgba(33,150,243,.4); background: rgba(33,150,243,.12); }
  .build-category[data-cat="RAM"]  { color: #CE93D8; border-color: rgba(206,147,216,.4); background: rgba(156,39,176,.12); }
  .build-category[data-cat="MB"]   { color: #FFB74D; border-color: rgba(255,183,77,.4); background: rgba(255,152,0,.12); }
  .build-category[data-cat="PSU"]  { color: #90A4AE; border-color: rgba(144,164,174,.4); background: rgba(96,125,139,.12); }
  .build-category[data-cat="CASE"] { color: #4DB6AC; border-color: rgba(77,182,172,.4); background: rgba(0,150,136,.12); }
  .build-name   { font-weight: 600; font-size: 13px; color: var(--c-text); }
  .build-reason { font-size: 12px; color: var(--c-muted); }
  .build-total-note { font-size: 10px; color: var(--c-muted); margin-left: 8px; opacity: .7; }
  .build-links  { display: flex; gap: 6px; margin-top: 4px; }
  .build-total {
    margin-top: 10px;
    padding-top: 8px;
    border-top: 1px solid rgba(255,255,255,.07);
    font-weight: 700;
    font-size: 14px;
    color: var(--c-text);
  }
  .build-tip {
    margin-top: 8px;
    font-size: 12px;
    color: var(--c-warn);
    background: var(--c-warn-bg);
    border: 1px solid rgba(255,217,120,.2);
    border-radius: 8px;
    padding: 8px 10px;
  }

  /* ── 構成サマリーカード ── */
  .summary-card {
    background: var(--bg-card);
    border: 1px solid var(--c-border);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    padding: 12px 14px;
    margin-top: 10px;
    width: min(460px, 75vw);
  }
  .summary-title {
    font-size: 11px;
    font-weight: 700;
    color: var(--c-muted);
    letter-spacing: .06em;
    text-transform: uppercase;
    margin-bottom: 8px;
  }
  .summary-rows {
    display: flex;
    flex-direction: column;
    gap: 4px;
    margin-bottom: 10px;
  }
  .summary-row {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    padding: 4px 0;
    border-bottom: 1px solid rgba(255,255,255,.04);
  }
  .summary-row:last-child { border-bottom: none; }
  .summary-cat {
    font-weight: 700;
    font-size: 10px;
    width: 42px;
    flex-shrink: 0;
    color: var(--c-muted);
  }
  .summary-name {
    flex: 1;
    color: var(--c-text);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .summary-name--empty {
    color: var(--c-muted);
    font-style: italic;
  }
  .summary-price {
    font-size: 11px;
    color: var(--c-sub);
    flex-shrink: 0;
    width: 64px;
    text-align: right;
  }
  .summary-status {
    font-size: 14px;
    flex-shrink: 0;
  }
  .summary-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 8px;
    border-top: 1px solid rgba(255,255,255,.07);
    flex-wrap: wrap;
    gap: 8px;
  }
  .summary-total-label {
    font-size: 13px;
    font-weight: 700;
    color: var(--c-text);
  }
  .summary-count {
    font-size: 11px;
    color: var(--c-muted);
  }

  /* ── カードサイズ傾斜 ── */
  .build-item--lg {
    padding: 12px 14px;
    border-left-width: 3px;
  }
  .build-item--md {
    padding: 10px 12px;
  }
  .build-item--sm {
    padding: 8px 10px;
    opacity: 0.85;
  }
  .build-item--sm .build-name {
    font-size: 12px;
  }
  .build-item--sm .build-reason {
    font-size: 11px;
  }

  /* ケースカードは大きめサムネ */
  .build-item--lg .build-thumb,
  .build-item--lg .build-thumb-icon {
    width: 56px;
    height: 56px;
    font-size: 26px;
  }

  /* ── モード切り替えボタン ── */
  .btn-mode-switch {
    margin-left: auto;
    padding: 4px 10px;
    border-radius: 20px;
    background: var(--bg-input);
    border: 1px solid var(--c-border);
    color: var(--c-sub);
    font-size: 12px;
    font-weight: 600;
    cursor: pointer;
    flex-shrink: 0;
    white-space: nowrap;
    transition: background .15s, border-color .15s;
    display: none;
  }
  .btn-mode-switch:hover { background: var(--bg-active); border-color: var(--c-primary); }

  /* ── 互換チェック引き渡しボタン ── */
  .btn-transfer-compat {
    display: block;
    width: 100%;
    margin-top: 10px;
    padding: 8px 12px;
    background: var(--c-primary);
    color: #fff;
    border: none;
    border-radius: 8px;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    text-align: center;
    transition: opacity .15s;
  }
  .btn-transfer-compat:hover { opacity: .85; }

  /* ── build-card 左寄せラッパー & レーダーチャート横並び ── */
  .build-card-wrap { padding: 2px 0; }
  .build-row {
    display: flex;
    gap: 12px;
    align-items: flex-start;
    flex-wrap: wrap;
  }
  .build-row .build-card { flex: 1; min-width: 280px; }
  .radar-wrap {
    flex: 0 0 280px;
    background: var(--bg-card);
    border: 1px solid var(--c-border);
    border-radius: 10px;
    padding: 12px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
  }
  .radar-title {
    font-size: 11px;
    color: var(--c-muted);
    font-weight: 600;
    letter-spacing: .04em;
    text-transform: uppercase;
  }

  /* 軸説明テキスト */
  .radar-axis-legend {
    font-size: 10px;
    color: var(--c-muted);
    line-height: 1.6;
    margin-top: 6px;
    text-align: left;
    width: 100%;
    padding: 0 4px;
  }
  .radar-axis-legend dt {
    display: inline;
    font-weight: 700;
    color: var(--c-sub);
  }
  .radar-axis-legend dd {
    display: inline;
    margin: 0 0 0 4px;
  }
  .radar-axis-legend .radar-axis-row {
    display: flex;
    gap: 4px;
    margin-bottom: 2px;
  }
  @media (max-width: 600px) {
    .build-row { flex-direction: column; }
    .radar-wrap { flex: 0 0 auto; width: 100%; }
    .summary-card { width: calc(100vw - 70px); }
    .summary-price { display: none; }
  }

  @media (max-width: 480px) {
    .alt-grid { grid-template-columns: 1fr; }
    .diag-card, .alt-grid, .build-card { width: calc(100vw - 70px); }
    .chat-area { padding: 14px 12px 6px; }
    .mode-cards { flex-direction: column; }
    .summary-card { width: calc(100vw - 70px); }
    .radar-wrap { flex: 0 0 auto; width: calc(100vw - 70px); }
  }

  /* ── 注目ゲームセクション ── */
  .featured-games {
    flex-shrink: 0;
    max-height: 220px;
    overflow-y: auto;
    padding: 12px 16px;
    background: var(--bg-main);
    border-bottom: 1px solid var(--c-border);
    position: relative;
  }
  
  /* モバイル: 折りたたみ可能 */
  @media (max-width: 1023px) {
    .featured-games.collapsed {
      max-height: 48px;
      overflow: hidden;
    }
    .featured-games.collapsed .game-cards {
      display: none;
    }
  }
  .featured-games::-webkit-scrollbar { width: 4px; }
  .featured-games::-webkit-scrollbar-thumb { background: #606975; border-radius: 2px; }

  .featured-title {
    font-size: 12px;
    font-weight: 700;
    color: var(--c-ok);
    margin-bottom: 10px;
    letter-spacing: .04em;
    display: flex;
    align-items: center;
    justify-content: space-between;
    cursor: pointer;
    user-select: none;
  }
  
  .featured-title .toggle-icon {
    font-size: 14px;
    transition: transform 0.2s;
  }
  
  .featured-games.collapsed .toggle-icon {
    transform: rotate(180deg);
  }
  
  @media (min-width: 1024px) {
    .featured-title {
      cursor: default;
    }
    .featured-title .toggle-icon {
      display: none;
    }
  }

  .game-cards {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 8px;
  }

  .game-card {
    position: relative;
    background: var(--bg-card);
    border-radius: 8px;
    padding: 12px 14px 10px;
    text-decoration: none;
    color: var(--c-text);
    transition: background .15s, border-color .15s;
    border: 1px solid var(--c-border);
    overflow: hidden;
    display: block;
  }
  .game-card:hover {
    background: var(--bg-active);
    border-color: var(--c-ok);
  }
  .game-card.featured {
    border-color: var(--c-warn);
    background: var(--c-warn-bg);
  }

  .game-badge {
    position: absolute;
    top: 8px;
    right: 8px;
    background: var(--c-ok);
    color: #1a1a2e;
    padding: 2px 8px;
    border-radius: 999px;
    font-size: 10px;
    font-weight: 700;
  }
  .game-card.featured .game-badge {
    background: var(--c-warn);
    color: #1a1a2e;
    animation: pulse 2s infinite;
  }
  @keyframes pulse {
    0%, 100% { transform: scale(1); }
    50%       { transform: scale(1.05); }
  }

  .game-card h3 {
    font-size: 12px;
    font-weight: 700;
    margin: 6px 0 4px;
    color: var(--c-ok);
    padding-right: 60px;
    line-height: 1.3;
  }
  .game-card.featured h3 { color: var(--c-warn); }

  .game-date {
    font-size: 10px;
    color: var(--c-muted);
    margin-bottom: 4px;
  }
  .game-spec {
    font-size: 10px;
    color: var(--c-sub);
    padding-top: 6px;
    border-top: 1px solid rgba(255,255,255,.06);
    line-height: 1.4;
  }

  @media (max-width: 480px) {
    .game-cards { grid-template-columns: 1fr 1fr; }
    .featured-games { max-height: 180px; }
  }
