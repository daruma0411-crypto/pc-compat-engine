# PC互換チェッカー 環境変数サンプル

# Claude API（必須）
ANTHROPIC_API_KEY=sk-ant-xxx

# Replicate API（画像生成機能に必要）
# https://replicate.com/account/api-tokens から取得
REPLICATE_API_TOKEN=r8_xxx

# Amazon アフィリエイトタグ
AMAZON_TAG=pccompat-22

# 楽天アフィリエイトID
RAKUTEN_A_ID=
RAKUTEN_L_ID=

# サイトURL（デフォルトはRailwayドメイン）
SITE_URL=https://pc-jisaku.com

# カスタムドメイン（独自ドメイン設定時に使用）
# CUSTOM_DOMAIN=pc-jisaku.com

# Railway デプロイ用
PORT=10000
