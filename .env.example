# PC互換性判定エンジン + エージェント群 環境変数
# =================================================
# このファイルを .env にコピーして実際の値を設定してください。
# cp .env.example .env
# ※ .env は .gitignore に登録済み（絶対にコミットしないこと）

# ── LLM Provider ─────────────────────────────────────
# Anthropic Claude (必須)
ANTHROPIC_API_KEY=sk-ant-xxx

# OpenAI (オプション: OpenAIモデルを使う場合)
# OPENAI_API_KEY=sk-xxx

# ── Google Cloud ─────────────────────────────────────
# サービスアカウントキーのパス
GOOGLE_APPLICATION_CREDENTIALS=./credentials.json

# ── PageIndex API ────────────────────────────────────
# スペック・マニュアルのインデックス登録に使用
PAGEINDEX_API_KEY=your-pageindex-key

# ── X (Twitter) API ──────────────────────────────────
# https://developer.twitter.com/ でアプリを作成して取得
# XMonitorAgent (FilteredStream) に使用
X_BEARER_TOKEN=AAAAAAAAAAAAxxxxxx

# X Monitor Scraper (Playwright スクレイピング用)
# scripts/x_monitor_scraper.py で使用
X_USERNAME=your-x-username-or-email
X_PASSWORD=your-x-password

# 検索クエリ（不要な場合はデフォルトの「グラボ 入らない」を使用）
X_SEARCH_QUERY=グラボ 入らない

# 取得上限件数（1回の実行で取得するツイート数）
MAX_TWEETS=20

# 診断API URL（たいていは変更不要）
COMPAT_API_URL=https://pc-compat-engine.onrender.com/api/diagnose

# XReplyAgent (リプライ送信) に使用
# OAuth 1.0a: Read and Write 権限が必要
X_API_KEY=your-api-key
X_API_SECRET=your-api-secret
X_ACCESS_TOKEN=your-access-token
X_ACCESS_TOKEN_SECRET=your-access-token-secret

# ── 診断エンジン API ─────────────────────────────────
# Web UI 等から直接エンジンを叩く場合のエンドポイント
# 未設定の場合はプロセス内呼び出しを使用
DIAGNOSE_API_URL=https://your-engine.example.com/api/diagnose

# ── リプライ詳細URL ──────────────────────────────────
# リプライに「詳細→ {URL}/{query_id}」を付与する場合に設定
# 空文字（デフォルト）の場合はURLをリプライに含めない
PCCOMPAT_DETAIL_URL_BASE=

# ── BigQuery ─────────────────────────────────────────
# PCPartsScraperAgent / ManualCollectorAgent のデータ保存先
# 未設定（空文字）の場合は dry-run: ログ出力のみで BQ 書き込みなし
BIGQUERY_PROJECT_ID=your-gcp-project-id
BIGQUERY_DATASET=pc_compat

# ── エンジン動作モード ───────────────────────────────
# true にするとモックモードで動作（LLM API 呼び出しなし）
# テスト・デモ環境向け
USE_MOCK_ENGINE=false
